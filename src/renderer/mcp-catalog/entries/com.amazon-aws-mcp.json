{
  "$schema": "../schema/entry.schema.json",
  "name": "com.amazon/aws-mcp",
  "title": "AWS",
  "description": "EC2, S3, Lambda, CloudFormation, and core AWS services via your AWS credentials.",
  "version": "1.0.0",
  "websiteUrl": "https://aws.amazon.com/mcp",
  "repository": { "url": "https://github.com/aws/mcp-server", "source": "github" },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@aws/mcp-server",
      "version": "1.0.0",
      "runtimeHint": "npx",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        { "name": "AWS_ACCESS_KEY_ID", "description": "IAM access key ID.", "isRequired": true, "isSecret": false },
        { "name": "AWS_SECRET_ACCESS_KEY", "description": "IAM secret access key.", "isRequired": true, "isSecret": true },
        { "name": "AWS_DEFAULT_REGION", "description": "Default AWS region (e.g. us-east-1).", "isRequired": false, "default": "us-east-1" },
        { "name": "AWS_SESSION_TOKEN", "description": "Session token (only required for temporary credentials).", "isRequired": false, "isSecret": true }
      ]
    }
  ],
  "x-wayland": {
    "tier": "builder",
    "categories": ["developer", "devops", "infrastructure"],
    "tags": ["aws", "cloud", "ec2", "s3"],
    "maintainerType": "official",
    "license": "Apache-2.0",
    "verifiedAt": "2026-05-12",
    "popularityRank": 38,
    "installRate": 0.20,
    "iconUrl": "icons/aws.svg",
    "brand": { "logoBackground": "#ffffff", "logoForeground": "#ff9900" },
    "auth": {
      "method": "api-key",
      "providerName": "AWS IAM",
      "providerSignupUrl": "https://aws.amazon.com"
    },
    "toolGroups": [
      { "label": "EC2", "count": 5 },
      { "label": "S3", "count": 4 },
      { "label": "Lambda", "count": 4 },
      { "label": "CloudFormation", "count": 3 }
    ],
    "setupGuide": { "path": "guides/com.amazon-aws-mcp.md", "estimatedMinutes": 4, "stepCount": 2 },
    "platforms": ["macos", "windows", "linux"],
    "minWaylandVersion": "0.8.0"
  }
}
