{
  "$schema": "../schema/entry.schema.json",
  "name": "com.sourcegraph/sourcegraph-mcp",
  "title": "Sourcegraph",
  "description": "Cross-repo code search, references, and definitions across your entire codebase — Sourcegraph's hosted MCP.",
  "version": "1.0.0",
  "websiteUrl": "https://docs.sourcegraph.com/integration/mcp",
  "repository": { "url": "https://github.com/sourcegraph/sourcegraph-mcp", "source": "github" },
  "packages": [],
  "remotes": [
    { "type": "streamable-http", "url": "https://mcp.sourcegraph.com" }
  ],
  "x-wayland": {
    "tier": "builder",
    "categories": ["developer", "code", "search"],
    "tags": ["sourcegraph", "code-search"],
    "maintainerType": "official",
    "license": "Apache-2.0",
    "verifiedAt": "2026-05-12",
    "popularityRank": 42,
    "installRate": 0.15,
    "iconUrl": "icons/sourcegraph.svg",
    "brand": { "logoBackground": "#ffffff", "logoForeground": "#ff5543" },
    "auth": {
      "method": "oauth2-byo",
      "providerName": "Sourcegraph",
      "providerSignupUrl": "https://sourcegraph.com",
      "scopes": [
        { "name": "user:read", "plainLanguage": "See your profile and accessible repos." },
        { "name": "code:read", "plainLanguage": "Search and read indexed code." }
      ]
    },
    "toolGroups": [
      { "label": "Search", "count": 4 },
      { "label": "References", "count": 3 },
      { "label": "Definitions", "count": 2 }
    ],
    "setupGuide": { "path": "guides/com.sourcegraph-sourcegraph-mcp.md", "estimatedMinutes": 1, "stepCount": 2 },
    "platforms": ["macos", "windows", "linux"],
    "minWaylandVersion": "0.8.0"
  }
}
