{
  "$schema": "../schema/entry.schema.json",
  "name": "com.clickhouse/clickhouse-mcp",
  "title": "ClickHouse",
  "description": "Read-only SQL and schema exploration over ClickHouse and chDB - ClickHouse’s official MCP.",
  "version": "1.0.0",
  "websiteUrl": "https://github.com/ClickHouse/mcp-clickhouse",
  "repository": {
    "url": "https://github.com/ClickHouse/mcp-clickhouse",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "mcp-clickhouse",
      "version": "latest",
      "runtimeHint": "uvx",
      "transport": {
